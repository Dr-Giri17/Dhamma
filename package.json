{
  "name": "dhamma",
  "version": "0.1.0",
  "private": true,
  "description": "Dhamma App — a source-grounded Theravāda Buddhist teaching companion.",
  "license": "MIT",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "ingest:dhammapada": "tsx scripts/ingest-dhammapada.ts",
    "ingest:bilara": "tsx scripts/ingest-bilara.ts",
    "build:index": "tsx scripts/build-search-index.ts && tsx scripts/corpus/build-full-index.ts",
    "corpus:metadata": "tsx scripts/corpus/build-metadata.ts",
    "corpus:validate": "tsx scripts/corpus/build-metadata.ts && tsx scripts/corpus/validate-full.ts",
    "corpus:validate:full": "tsx scripts/corpus/validate-full.ts",
    "corpus:inventory:vri": "tsx scripts/corpus/vri.ts inventory",
    "corpus:inventory:bilara": "tsx scripts/corpus/bilara.ts inventory",
    "corpus:inventory:theravada": "tsx scripts/corpus/theravada.ts inventory",
    "corpus:ingest:pali": "tsx scripts/corpus/vri.ts ingest",
    "corpus:ingest:en": "tsx scripts/corpus/bilara.ts ingest",
    "corpus:ingest:ru": "tsx scripts/corpus/theravada.ts ingest",
    "corpus:coverage": "tsx scripts/corpus/vri.ts coverage"
  },
  "dependencies": {
    "next": "15.5.20",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@types/node": "22.10.7",
    "@types/react": "19.0.7",
    "@types/react-dom": "19.0.3",
    "autoprefixer": "10.4.20",
    "eslint": "9.39.4",
    "eslint-config-next": "15.5.20",
    "postcss": "8.5.10",
    "tailwindcss": "3.4.17",
    "tsx": "4.23.0",
    "typescript": "5.7.3",
    "vitest": "3.2.7"
  },
  "engines": {
    "node": ">=20"
  }
}
